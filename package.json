{
  "name": "esg-virtual-human",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "commit": "cz",
    "dev": "vite",
    "format": "oxfmt --write .",
    "lint": "oxlint . --fix",
    "prepare": "husky",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "lottie-web": "^5.13.0",
    "tailwindcss": "^4.3.2",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/cz-commitlint": "^21.2.0",
    "@types/node": "24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "commitizen": "^4.3.2",
    "eruda": "^3.4.3",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx,vue}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.{css,html,json,md}": "oxfmt --write"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.6.0"
}
