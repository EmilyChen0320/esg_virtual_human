{
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "jsxSingleQuote": false,
  "printWidth": 100,
  "proseWrap": "preserve",
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "none",
  "useTabs": false,
  "embeddedLanguageFormatting": "auto",
  "experimentalSortImports": {
    "groups": [
      ["side_effect"],
      ["builtin"],
      ["value-external", "type-external"],
      ["value-internal", "type-internal"],
      ["value-parent", "type-parent"],
      ["value-sibling", "type-sibling"],
      ["value-index", "type-index"]
    ]
  },
  "experimentalTailwindcss": {
    "stylesheet": "./src/style.css",
    "attributes": ["class", "className", "/data-.*/"],
    "functions": ["clsx", "cn"],
    "preserveDuplicates": false,
    "preserveWhitespace": false
  },
  "experimentalSortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": [
    "**/coverage",
    "**/dist",
    "public/lib/**",
    "refer/**",
    "src/lib/srs.sdk.js",
    ".DS_Store",
    "*.pem",
    "npm-debug.log*",
    "yarn-debug.log*",
    "yarn-error.log*",
    ".pnpm-debug.log*",
    "**/.env*",
    "env.example"
  ]
}
